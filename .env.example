# Atlas MCP — Variáveis de ambiente
# Copie para .env e ajuste conforme necessário

# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_dev
POSTGRES_DB=atlas_mcp
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Conexão (DSN completa — alternativa às variáveis individuais)
# DATABASE_URL=postgresql://atlas:atlas_dev@localhost:5432/atlas_mcp

# Pool de conexões
# DB_MIN_POOL_SIZE=2
# DB_MAX_POOL_SIZE=10

# ── Embeddings ───────────────────────────────────────────
# Provider: "openai" (padrão) ou "sentence-transformers" (local, sem API key)
EMBEDDING_PROVIDER=openai

# Modelo de embeddings (padrões: text-embedding-3-small / all-MiniLM-L6-v2)
# EMBEDDING_MODEL=text-embedding-3-small

# Dimensão do vetor (padrões: 1536 para OpenAI / 384 para sentence-transformers)
# EMBEDDING_DIMENSION=1536

# API key do OpenAI (obrigatória se EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here

# ── Servidor ─────────────────────────────────────────────
# Transporte MCP: "stdio" (padrão) ou "sse" (HTTP)
ATLAS_TRANSPORT=stdio

# Host e porta para transporte SSE (ignorados com stdio)
# ATLAS_SSE_HOST=0.0.0.0
# ATLAS_SSE_PORT=8000

# ── Logging ──────────────────────────────────────────────
# Nível: DEBUG, INFO (padrão), WARNING, ERROR, CRITICAL
ATLAS_LOG_LEVEL=INFO

# Formato: "text" (padrão, legível) ou "json" (estruturado)
ATLAS_LOG_FORMAT=text
